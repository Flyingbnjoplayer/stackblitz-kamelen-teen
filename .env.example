# ===========================================
# Glitch NFT Studio - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git!

# ===========================================
# NFT Storage (IPFS uploads)
# ===========================================
# Get your API key at: https://nft.storage/
NFT_STORAGE_TOKEN=your_nft_storage_api_key_here

# ===========================================
# Vercel Blob Storage (image uploads)
# ===========================================
# Auto-created when you add Blob storage in Vercel dashboard
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here

# ===========================================
# Coinbase OnchainKit (wallet connection)
# ===========================================
# Get your keys at: https://portal.cdp.coinbase.com/
NEXT_PUBLIC_ONCHAINKIT_API_KEY=your_onchainkit_api_key_here
NEXT_PUBLIC_ONCHAINKIT_PROJECT_ID=your_onchainkit_project_id_here

# ===========================================
# WalletConnect (optional, for additional wallets)
# ===========================================
# Get your project ID at: https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# ===========================================
# Base Network RPC URLs
# ===========================================
# Get your API key at: https://www.alchemy.com/ (sign up for free)
# Or use public RPCs (rate limited):
#   Base Mainnet: https://mainnet.base.org
#   Base Sepolia: https://sepolia.base.org

# Base Mainnet RPC
NEXT_PUBLIC_BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/your_alchemy_api_key_here
ALCHEMY_BASE_MAINNET_HTTP=https://base-mainnet.g.alchemy.com/v2/your_alchemy_api_key_here

# Base Sepolia Testnet RPC (for testing)
ALCHEMY_BASE_SEPOLIA_HTTP=https://base-sepolia.g.alchemy.com/v2/your_alchemy_api_key_here

# ===========================================
# Network Configuration
# ===========================================
# Chain ID: 8453 = Base Mainnet, 84532 = Base Sepolia Testnet
NEXT_PUBLIC_DEFAULT_CHAIN_ID=8453

# ===========================================
# Smart Contract (after deployment)
# ===========================================
# Will be filled in after deploying your NFT contract
NEXT_PUBLIC_NFT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ===========================================
# Contract Deployment (Hardhat)
# ===========================================
# ⚠️ NEVER commit your actual private key!
# Use a dedicated deployer wallet with minimal funds
PRIVATE_KEY=your_deployer_wallet_private_key_here
